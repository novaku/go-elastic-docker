# ─────────────────────────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────────────────────────
APP_NAME=go-elastic-search
APP_ENV=development          # development | production
APP_PORT=8080
READ_TIMEOUT_SECONDS=10
WRITE_TIMEOUT_SECONDS=30
CORS_ALLOWED_ORIGINS=*       # In production: https://yourdomain.com

# ─────────────────────────────────────────────────────────────────
# Elasticsearch
# ─────────────────────────────────────────────────────────────────

# Comma-separated list of node addresses
ES_ADDRESSES=http://localhost:9200

# Basic auth (leave empty for local dev without security)
ES_USERNAME=
ES_PASSWORD=

# API Key auth (alternative to username/password)
ES_API_KEY=

# TLS — path to CA certificate (required when xpack.security is on)
ES_CA_CERT=

# Elastic Cloud ID (alternative to ES_ADDRESSES for Elastic Cloud)
ES_CLOUD_ID=

# ─────────────────────────────────────────────────────────────────
# Production extras (only used in docker-compose.prod.yml)
# ─────────────────────────────────────────────────────────────────
ES_CLUSTER_NAME=prod-cluster
API_IMAGE=yourorg/go-elastic-search:latest
