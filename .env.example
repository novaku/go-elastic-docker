# Runtime selector for app config file:
# - APP_ENV=local      -> load config/local.json
# - APP_ENV=production -> load config/production.json
APP_ENV=local

# ─────────────────────────────────────────────────────────────────
# Production extras (only used in docker-compose.prod.yml)
# ─────────────────────────────────────────────────────────────────
ES_CLUSTER_NAME=prod-cluster
ES_PASSWORD=changeme
API_IMAGE=yourorg/go-elastic-search:latest
